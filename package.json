{
  "name": "lister",
  "version": "0.1.0",
  "description": "Simple, fast, opinionated list management for agentic workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tool": {
      "types": "./dist/tool.d.ts",
      "import": "./dist/tool.js"
    }
  },
  "files": [
    "dist",
    "openclaw",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "prepack": "npm test",
    "test": "npm run test:integration",
    "test:integration": "npm run build && node --test test/integration.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "lists",
    "agent"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "openclaw": "^2026.4.15",
    "typescript": "^5.8.3"
  }
}
